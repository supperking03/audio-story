{
  "expo": {
    "name": "BuBu: Truyện Audio",
    "slug": "bubu-truyen-audio",
    "scheme": "audiostory",
    "version": "1.0.7",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "favicon": "./assets/favicon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B11"
    },
    "android": {
      "package": "com.supperking03.audiostory",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#150942"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0A0B11",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da2a6e10-ed50-48fb-b93e-65f0ebdbc532"
      }
    },
    "ios": {
      "bundleIdentifier": "com.supperking03.audio-story",
      "buildNumber": "9",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "owner": "supperking03"
  }
}
